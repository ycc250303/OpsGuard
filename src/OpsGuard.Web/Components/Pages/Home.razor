@page "/"
@rendermode InteractiveServer
@using OpsGuard.App.Services.Conversations
@using OpsGuard.Core.Configuration
@using OpsGuard.Core.Memory
@using OpsGuard.App.Services
@inject DiagnosticSessionService Session
@inject IUserModelSelection ModelSelection
@inject WebAppInfo AppInfo
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>OpsGuard 运维诊断</PageTitle>

<div class="ops-shell">
    <div class="ops-atmosphere ops-atmosphere--lite" aria-hidden="true">
        <span class="ops-orb orb-cyan"></span>
        <span class="ops-orb orb-amber"></span>
        <span class="ops-orb orb-blue"></span>
        <span class="ops-scanline"></span>
    </div>

    @if (Session.PersistenceEnabled)
    {
        <aside class="ops-sidebar">
            <div class="ops-sidebar-header">
                <div>
                    <span class="ops-kicker">Session Vault</span>
                    <h2>会话</h2>
                </div>
                <button type="button" class="btn-sidebar-new" @onclick="CreateSessionAsync" disabled="@_isRunning">新建</button>
            </div>
            <ul class="ops-session-list">
                @foreach (var summary in Session.SessionSummaries)
                {
                    <li class="ops-session-item @(summary.Id == Session.ActiveSessionId ? "active" : "")">
                        <button type="button"
                                class="ops-session-button"
                                @onclick="() => SwitchSessionAsync(summary.Id)"
                                disabled="@_isRunning">
                            <span class="ops-session-title">@summary.Title</span>
                            <span class="ops-session-meta">@summary.UpdatedAt.ToLocalTime().ToString("MM-dd HH:mm")</span>
                        </button>
                        @if (Session.SessionSummaries.Count > 1)
                        {
                            <button type="button"
                                    class="ops-session-delete"
                                    title="删除会话"
                                    @onclick="() => DeleteSessionAsync(summary.Id)"
                                    disabled="@_isRunning">×</button>
                        }
                    </li>
                }
            </ul>
            <div class="ops-sidebar-footer">
                <span class="ops-kicker">Telemetry</span>
                <div class="ops-mini-meter">
                    <span style="--meter: 78%"></span>
                </div>
                <div class="ops-mini-grid">
                    <span>Trace</span>
                    <strong>Live</strong>
                    <span>Queue</span>
                    <strong>@Session.SessionSummaries.Count</strong>
                </div>
            </div>
        </aside>
    }

    <div class="ops-page">
        <header class="ops-header">
            <div class="ops-title-block">
                <span class="ops-kicker">Autonomous Infra Console</span>
                <h1>OpsGuard</h1>
                <p class="ops-subtitle">Linux 主机 + Docker Compose 运维诊断 Agent</p>
                <div class="ops-signal-row" aria-label="系统能力">
                    <span>Host Metrics</span>
                    <span>Compose Topology</span>
                    <span>Streaming Diagnosis</span>
                </div>
            </div>
            <div class="ops-command-deck">
                <div class="ops-radar" aria-hidden="true">
                    <span></span>
                    <i></i>
                    <b></b>
                </div>
                <div class="ops-meta">
                    <button type="button" class="btn-settings" @onclick="OpenSettings" disabled="@_isRunning" title="设置">
                        <span class="ops-settings-icon" aria-hidden="true">⚙</span>
                        设置
                    </button>
                    <span class="ops-model-badge">模型: @ModelSelection.ModelId</span>
                    <span class="ops-topology">本机: @_machineName (@_osPlatform)</span>
                </div>
                <div class="ops-vital-grid" aria-label="运行面板">
                    <div>
                        <span>Runtime</span>
                        <strong>@(_isRunning ? "ACTIVE" : "STANDBY")</strong>
                    </div>
                    <div>
                        <span>Sessions</span>
                        <strong>@Session.SessionSummaries.Count</strong>
                    </div>
                    <div>
                        <span>Stream</span>
                        <strong>@(_isRunning ? "OPEN" : "IDLE")</strong>
                    </div>
                </div>
            </div>
        </header>

        <section class="ops-chat" @ref="_chatContainer">
            @if (Session.Messages.Count == 0)
            {
                <div class="ops-empty">
                    <div class="ops-empty-copy">
                        <span class="ops-kicker">Ready for triage</span>
                        <h2>把故障现象直接丢进来，OpsGuard 会读取本机 Docker 与主机指标。</h2>
                        <div class="ops-prompt-grid">
                            <button type="button" @onclick="UseFullInspectionPrompt" disabled="@_isRunning">
                                <strong>全量巡检</strong>
                                <span>检查本机和所有配置的 compose 服务</span>
                            </button>
                            <button type="button" @onclick="UseBackendPrompt" disabled="@_isRunning">
                                <strong>容器状态</strong>
                                <span>backend 容器运行正常吗？</span>
                            </button>
                            <button type="button" @onclick="UseGatewayPrompt" disabled="@_isRunning">
                                <strong>健康检查</strong>
                                <span>web-gateway 健康检查失败</span>
                            </button>
                        </div>
                        <p class="ops-hint">检测对象为<strong>运行本程序的服务器</strong>（读本地 Docker / Host 指标）。</p>
                    </div>
                    <aside class="ops-mission-card" aria-label="诊断流程">
                        <div class="ops-core-orbit">
                            <span class="ops-orbit-runner ops-orbit-runner--1" aria-hidden="true"><i></i></span>
                            <span class="ops-orbit-runner ops-orbit-runner--2" aria-hidden="true"><i></i></span>
                            <span class="ops-orbit-runner ops-orbit-runner--3" aria-hidden="true"><i></i></span>
                        </div>
                        <dl>
                            <div>
                                <dt>01</dt>
                                <dd>Collect host signals</dd>
                            </div>
                            <div>
                                <dt>02</dt>
                                <dd>Map compose topology</dd>
                            </div>
                            <div>
                                <dt>03</dt>
                                <dd>Stream agent reasoning</dd>
                            </div>
                        </dl>
                        <div class="ops-spectrum">
                            <span></span><span></span><span></span><span></span><span></span><span></span>
                        </div>
                    </aside>
                </div>
            }
            else
            {
                <div class="ops-feed-header">
                    <span class="ops-kicker">Diagnostic Stream</span>
                    <div>
                        <span>@Session.Messages.Count messages</span>
                        <span>@(_isRunning ? "Agent running" : "Review mode")</span>
                    </div>
                </div>

                @for (var index = 0; index < Session.Messages.Count; index++)
                {
                    var message = Session.Messages[index];
                    <article @key="@($"{message.Role}-{index}-{message.At.ToUnixTimeMilliseconds()}")" class="ops-message @(message.IsUser ? "user" : "assistant")">
                        <div class="ops-message-chrome">
                            <div class="ops-message-role">
                                <span class="ops-message-avatar">@(message.IsUser ? "U" : "AI")</span>
                                <div>
                                    <strong>@(message.IsUser ? "Operator" : "OpsGuard Agent")</strong>
                                    <small>@(message.IsUser ? "Manual command" : (_isRunning && message == Session.Messages.Last() ? "Streaming analysis" : "Diagnostic report"))</small>
                                </div>
                            </div>
                            <div class="ops-message-status" aria-hidden="true">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                        <div class="ops-message-panel">
                            @if (message.IsUser)
                            {
                                <div class="ops-message-body">@message.Content</div>
                            }
                            else if (_isRunning && index == Session.Messages.Count - 1)
                            {
                                <div @ref="_liveStreamHost" class="ops-message-body markdown streaming" data-live-stream="true">
                                    <span class="ops-cursor">▍</span>
                                </div>
                            }
                            else
                            {
                                <AssistantMessageBody Content="@message.Content" IsStreaming="false" />
                            }
                        </div>
                        <footer class="ops-message-footer">
                            <span>@(message.IsUser ? "USER_TX" : "AGENT_RX")</span>
                            <time class="ops-message-time">@message.At.ToLocalTime().ToString("HH:mm:ss")</time>
                        </footer>
                    </article>
                }
            }

            @if (_isRunning && !HasStreamingAssistantMessage())
            {
                <div class="ops-loading">
                    <span class="ops-spinner"></span>
                    正在启动诊断…
                </div>
            }
        </section>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="ops-error">@_error</div>
        }

        <footer class="ops-input-bar">
            <div class="ops-input-label">
                <span>Command Input</span>
                <span>Enter 发送 · Shift + Enter 换行</span>
            </div>
            <textarea @ref="_inputRef"
                      id="ops-command-input"
                      @onkeydown="HandleKeyDown"
                      @oncompositionstart="HandleCompositionStart"
                      @oncompositionend="HandleCompositionEnd"
                      placeholder="描述你要排查的问题…"
                      rows="2"
                      disabled="@_isRunning"></textarea>
            <div class="ops-actions">
                <div class="ops-command-chips" aria-hidden="true">
                    <span>docker ps</span>
                    <span>compose logs</span>
                    <span>host load</span>
                </div>
                <button type="button" class="btn-primary" @onclick="SendAsync" disabled="@_isRunning">发送</button>
            </div>
        </footer>
    </div>
</div>

<SettingsPanel IsOpen="_settingsOpen"
               ModelId="@ModelSelection.ModelId"
               OnClose="CloseSettings"
               OnSave="SaveSettingsAsync" />

@code {
    private ElementReference _chatContainer;
    private ElementReference _inputRef;
    private string? _error;
    private bool _isRunning;
    private bool _isComposing;
    private bool _settingsOpen;
    private ElementReference _liveStreamHost;
    private bool _bindLiveStream;
    private bool _streamListSynced;
    private CancellationTokenSource? _cts;
    private readonly string _machineName = OpsGuardRuntimeContext.Current().MachineName;
    private readonly string _osPlatform = OpsGuardRuntimeContext.Current().OsPlatform;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ModelSelection.InitializeAsync();
            await Session.InitializeAsync();
            StateHasChanged();
        }

        if (_bindLiveStream)
        {
            _bindLiveStream = false;
            await JS.InvokeVoidAsync("diagStream.bind", _liveStreamHost);
        }
    }

    private void OpenSettings() => _settingsOpen = true;

    private void CloseSettings() => _settingsOpen = false;

    private void UseFullInspectionPrompt() => _ = SetInputPromptAsync("检查本机和所有配置的 compose 服务");

    private void UseBackendPrompt() => _ = SetInputPromptAsync("backend 容器运行正常吗？");

    private void UseGatewayPrompt() => _ = SetInputPromptAsync("web-gateway 健康检查失败");

    private async Task SetInputPromptAsync(string prompt)
    {
        await JS.InvokeVoidAsync("opsInput.setValue", _inputRef, prompt);
    }

    private Task SaveSettingsAsync(string modelId)
    {
        ModelSelection.SetModelId(modelId);
        return Task.CompletedTask;
    }

    private async Task CreateSessionAsync()
    {
        _error = null;
        try
        {
            await Session.CreateSessionAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SwitchSessionAsync(string sessionId)
    {
        _error = null;
        try
        {
            await Session.SwitchSessionAsync(sessionId);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteSessionAsync(string sessionId)
    {
        _error = null;
        try
        {
            await Session.DeleteSessionAsync(sessionId);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SendAsync()
    {
        _error = null;
        var question = await JS.InvokeAsync<string>("opsInput.getValue", _inputRef);
        if (question.Length == 0 || _isRunning)
        {
            return;
        }

        await JS.InvokeVoidAsync("opsInput.clear", _inputRef);
        _streamListSynced = false;
        _isRunning = true;
        _bindLiveStream = true;
        _cts = new CancellationTokenSource(TimeSpan.FromMinutes(15));

        try
        {
            await Session.AskStreamingAsync(
                question,
                OnDiagnosticUpdatedAsync,
                _cts.Token);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            await JS.InvokeVoidAsync("diagStream.unbind");
            _isRunning = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private async Task OnDiagnosticUpdatedAsync()
    {
        if (!_streamListSynced)
        {
            _streamListSynced = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await PushLiveStreamUpdateAsync();
    }

    private async Task PushLiveStreamUpdateAsync()
    {
        var markdown = Session.Messages.LastOrDefault(message => !message.IsUser)?.Content ?? string.Empty;
        await JS.InvokeVoidAsync("diagStream.update", markdown);
    }

    private void HandleCompositionStart() => _isComposing = true;

    private void HandleCompositionEnd() => _isComposing = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !e.IsComposing && !_isComposing)
        {
            await SendAsync();
        }
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("diagStream.unbind");
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private bool HasStreamingAssistantMessage()
    {
        var last = Session.Messages.LastOrDefault();
        return last is { IsUser: false } && !string.IsNullOrWhiteSpace(last.Content);
    }
}
